<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                        https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
  <entity
    name="Siganushka\TransactionBundle\Entity\Transaction"
    inheritance-type="SINGLE_TABLE"
    repository-class="Siganushka\TransactionBundle\Repository\TransactionRepository">
    <unique-constraints>
      <unique-constraint columns="number" />
    </unique-constraints>

    <id name="id" type="integer">
      <generator strategy="AUTO"/>
    </id>

    <field name="number" type="string" />
    <field name="amount" type="integer" />
    <field name="payMethod" type="string" nullable="true" />
    <field name="payRequest" type="json" nullable="true" />
    <field name="payResponse" type="json" nullable="true" />
    <field name="successful" type="boolean" />
    <field name="expiredAt" type="datetime_immutable" nullable="true" />
    <field name="createdAt" type="datetime_immutable" />
    <field name="updatedAt" type="datetime_immutable" nullable="true" />
  </entity>
</doctrine-mapping>
